# Postgres superuser password
POSTGRES_PASSWORD=grindpass
# PostgREST authenticator role password
AUTHENTICATOR_PASSWORD=authenticatorpass
# GoTrue auth admin role password
AUTH_ADMIN_PASSWORD=authadminpass

# GoTrue JWT signing secret
GOTRUE_JWT_SECRET=test-jwt-secret-do-not-use-in-production
# PostgREST JWT verification secret (must match GOTRUE_JWT_SECRET)
PGRST_JWT_SECRET=test-jwt-secret-do-not-use-in-production

# Google OAuth client credentials
# Authorized redirect URI: http://localhost:9999/callback
GOTRUE_EXTERNAL_GOOGLE_CLIENT_ID=
GOTRUE_EXTERNAL_GOOGLE_SECRET=

# Frontend app URL (for redirects and CORS)
VITE_SITE_URL=http://localhost:5173
# GoTrue public URL (used by frontend)
VITE_GOTRUE_URL=http://localhost:9999